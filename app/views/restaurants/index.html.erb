<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-4 fw-bold">Restaurants</h1>
    <%= link_to "Add restaurant", new_restaurant_path, class: "btn btn-primary btn-lg shadow-sm" %>
  </div>

  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% @restaurants.each do |restaurant| %>
      <div class="col">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body">
            <h5 class="card-title fw-bold text-primary"><%= restaurant.name %></h5>
            <p class="card-text text-muted">
              <span class="badge bg-light text-dark"><%= restaurant.category.capitalize %></span>
            </p>
            <p class="card-text"><i class="bi bi-geo-alt"></i> <%= restaurant.address %></p>
          </div>
          <div class="card-footer bg-white border-0 pb-3">
            <%= link_to "View Details", restaurant_path(restaurant), class: "btn btn-outline-primary w-100" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
