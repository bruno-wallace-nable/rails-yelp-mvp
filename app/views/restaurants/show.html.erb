<div class="container mt-5">
  <h1><%= @restaurant.name %></h1>
  <p><strong>Address:</strong> <%= @restaurant.address %></p>
  <p><strong>Category:</strong> <%= @restaurant.category %></p>

  <hr>

  <h3>Reviews</h3>
  <% if @restaurant.reviews.any? %>
    <ul class="list-group mb-3">
      <% @restaurant.reviews.each do |review| %>
        <li class="list-group-item">
          <p class="mb-1"><%= review.content %></p>
          <small class="text-muted"><%= "★" * review.rating %></small>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p><em>No reviews yet. Be the first to leave one!</em></p>
  <% end %>

  <hr>

  <h3>Add a Review</h3>

  <%= simple_form_for [@restaurant, @review] do |f| %>
    <%= f.input :content, label: "Your opinion" %>
    <%= f.input :rating, collection: 0..5, label: "Rating (0-5)" %>
    <%= f.submit "Submit Review", class: "btn btn-primary" %>
  <% end %>

  <div class="mt-4 mb-5">
    <%= link_to "Back to the list", restaurants_path, class: "btn btn-secondary" %>
  </div>
</div>
